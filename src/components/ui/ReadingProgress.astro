---
interface Props {
    readingTime: number;
}

const { readingTime } = Astro.props;

// SVG circle geometry
const size = 48;
const strokeWidth = 3;
const radius = (size - strokeWidth) / 2;
const circumference = 2 * Math.PI * radius;
---

<div id="reading-pill" class="reading-pill" aria-hidden="true" data-reading-time={readingTime}>
    <svg class="reading-pill-ring" width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
        <circle
            class="reading-pill-track"
            cx={size / 2}
            cy={size / 2}
            r={radius}
            fill="none"
            stroke-width={strokeWidth}
        />
        <circle
            id="reading-pill-progress"
            class="reading-pill-fill"
            cx={size / 2}
            cy={size / 2}
            r={radius}
            fill="none"
            stroke-width={strokeWidth}
            stroke-linecap="round"
            stroke-dasharray={circumference}
            stroke-dashoffset={circumference}
        />
    </svg>
    <span id="reading-pill-label" class="reading-pill-label">
        {readingTime}m
    </span>
    <svg id="reading-pill-bookmark" class="reading-pill-bookmark" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
    </svg>
    <svg id="reading-pill-check" class="reading-pill-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
</div>

<style define:vars={{ circumference: String(circumference) }}>
    .reading-pill {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 40;
        display: grid;
        place-items: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: color-mix(in oklch, var(--color-bg-secondary), transparent 15%);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--color-border);
        cursor: default;
        opacity: 0;
        transform: translateY(16px) scale(0.9);
        transition:
            opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
            box-shadow 0.3s ease,
            border-color 0.3s ease;
        pointer-events: none;
    }

    .reading-pill.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    .reading-pill.done {
        border-color: var(--color-accent);
    }

    /* Clickable when visible and not done */
    .reading-pill.visible:not(.done) {
        cursor: pointer;
    }

    :global(.dark) .reading-pill {
        box-shadow:
            0 0 12px color-mix(in oklch, var(--color-accent), transparent 80%),
            0 4px 16px rgba(0, 0, 0, 0.4);
    }

    :global(.dark) .reading-pill.done {
        box-shadow:
            0 0 16px color-mix(in oklch, var(--color-accent), transparent 50%),
            0 4px 16px rgba(0, 0, 0, 0.4);
    }

    .reading-pill-ring {
        position: absolute;
        inset: 0;
        transform: rotate(-90deg);
    }

    .reading-pill-track {
        stroke: var(--color-border);
    }

    .reading-pill-fill {
        stroke: var(--color-accent);
        transition: stroke-dashoffset 0.15s ease-out;
    }

    .reading-pill-label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-secondary);
        line-height: 1;
        user-select: none;
        transition: opacity 0.2s ease;
    }

    .reading-pill.done .reading-pill-label {
        opacity: 0;
        position: absolute;
    }

    /* Bookmark icon — hidden by default */
    .reading-pill-bookmark {
        width: 18px;
        height: 18px;
        color: var(--color-accent);
        fill: none;
        opacity: 0;
        transform: scale(0.8);
        transition:
            opacity 0.2s ease,
            transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
            fill 0.2s ease;
        position: absolute;
        pointer-events: none;
    }

    /* Hover: show outline bookmark, hide label */
    .reading-pill:hover:not(.done):not(.has-saved) .reading-pill-bookmark {
        opacity: 1;
        transform: scale(1);
    }

    .reading-pill:hover:not(.done):not(.has-saved) .reading-pill-label {
        opacity: 0;
    }

    /* Has saved position: show filled bookmark */
    .reading-pill.has-saved .reading-pill-bookmark {
        opacity: 1;
        transform: scale(1);
        fill: currentColor;
    }

    .reading-pill.has-saved .reading-pill-label {
        opacity: 0;
    }

    .reading-pill.has-saved {
        border-color: var(--color-accent);
    }

    /* Pulse animation for resume indicator */
    .reading-pill.has-saved .reading-pill-fill {
        animation: pulse-ring 2s ease-in-out infinite;
    }

    @keyframes pulse-ring {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    /* Check icon (done state) */
    .reading-pill-check {
        width: 20px;
        height: 20px;
        color: var(--color-accent);
        opacity: 0;
        transform: scale(0.5);
        transition:
            opacity 0.3s ease 0.1s,
            transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s;
        position: absolute;
    }

    .reading-pill.done .reading-pill-check {
        opacity: 1;
        transform: scale(1);
    }

    .reading-pill.done .reading-pill-bookmark {
        opacity: 0;
        transform: scale(0.5);
    }

    @media (max-width: 640px) {
        .reading-pill {
            bottom: 1.25rem;
            right: 1.25rem;
        }
    }
</style>

<script>
    const pill = document.getElementById('reading-pill')!;
    const progressCircle = document.getElementById('reading-pill-progress')!;
    const label = document.getElementById('reading-pill-label')!;
    const article = document.querySelector('article')!;

    const totalMinutes = Number(pill.dataset.readingTime);
    const circumference = Number(getComputedStyle(pill).getPropertyValue('--circumference'));
    const storageKey = `reading-progress:${location.pathname}`;

    let ticking = false;
    let currentProgress = 0;
    let hasResumed = false;

    // Check for saved position
    const savedValue = localStorage.getItem(storageKey);
    let savedProgress: number | null = savedValue !== null ? Number(savedValue) : null;

    if (savedProgress !== null && savedProgress > 0.02 && savedProgress < 0.95) {
        pill.classList.add('has-saved', 'visible');
    } else {
        savedProgress = null;
        localStorage.removeItem(storageKey);
    }

    pill.addEventListener('click', () => {
        if (pill.classList.contains('done')) return;

        if (pill.classList.contains('has-saved')) {
            // Resume on first click after reload, then unsave
            if (!hasResumed && savedProgress !== null) {
                const rect = article.getBoundingClientRect();
                const articleTop = rect.top + window.scrollY;
                const total = rect.height - window.innerHeight;
                window.scrollTo({ top: articleTop + total * savedProgress, behavior: 'smooth' });
                hasResumed = true;
            }
            // Toggle off
            pill.classList.remove('has-saved');
            localStorage.removeItem(storageKey);
            savedProgress = null;
        } else {
            // Save current position
            if (currentProgress >= 0.98 || currentProgress < 0.02) return;
            localStorage.setItem(storageKey, String(currentProgress));
            savedProgress = currentProgress;
            hasResumed = false;
            pill.classList.add('has-saved');
        }
    });

    function update() {
        const rect = article.getBoundingClientRect();
        const articleTop = rect.top + window.scrollY;
        const articleHeight = rect.height;
        const viewportHeight = window.innerHeight;

        const scrolled = window.scrollY - articleTop;
        const total = articleHeight - viewportHeight;
        const progress = Math.min(1, Math.max(0, scrolled / total));
        currentProgress = progress;

        // Show pill once we've scrolled a bit into the article
        const pastHero = window.scrollY > articleTop - viewportHeight * 0.6;
        const shouldShow = pastHero && progress < 1;
        // Always visible while bookmark is saved
        pill.classList.toggle('visible', shouldShow || pill.classList.contains('has-saved'));

        pill.classList.toggle('done', progress >= 0.98);

        // When done, keep visible briefly and clear saved progress
        if (progress >= 0.98) {
            pill.classList.add('visible');
            pill.classList.remove('has-saved');
            localStorage.removeItem(storageKey);
        }

        // Update ring
        const offset = circumference * (1 - progress);
        progressCircle.style.strokeDashoffset = String(offset);

        // Update remaining time
        const remaining = Math.max(1, Math.ceil(totalMinutes * (1 - progress)));
        if (progress < 0.98) {
            label.textContent = `${remaining}m`;
        }

        ticking = false;
    }

    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
        }
    }, { passive: true });

    update();
</script>
