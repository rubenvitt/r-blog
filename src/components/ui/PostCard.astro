---
interface Props {
    title: string;
    description: string;
    date: Date;
    tags: string[];
    slug: string;
}

const {title, description, date, tags, slug} = Astro.props;

const formattedDate = date.toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block">
    <article class="py-5 border-b border-(--color-border) transition-colors">
        <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
                <h3 class="font-semibold text-(--color-text) group-hover:text-(--color-accent) transition-colors tracking-tight">
                    {title}
                </h3>
                <p class="mt-1 text-sm text-(--color-text-secondary) line-clamp-2">
                    {description}
                </p>
                {tags.length > 0 && (
                        <div class="mt-2 flex flex-wrap gap-1.5">
                            {tags.map((tag) => (
                                    <span class="rounded-full bg-(--color-border) px-2 py-0.5 text-xs text-(--color-text-muted)">
                {tag}
              </span>
                            ))}
                        </div>
                )}
            </div>
            <time
                    datetime={date.toISOString()}
                    class="shrink-0 text-sm text-(--color-text-muted) pt-0.5"
            >
                {formattedDate}
            </time>
        </div>
    </article>
</a>
