---
interface Props {
    tag: string;
    variant?: 'default' | 'hero';
}

const {tag, variant = 'default'} = Astro.props;
---

{variant === 'hero' ? (
<a
        href={`/tags/${tag}`}
        class="inline-block rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/80 hover:bg-white/20 hover:text-white transition-colors"
>
    {tag}
</a>
    ) : (
<a
        href={`/tags/${tag}`}
        class="inline-block rounded-full bg-(--color-border) px-3 py-1 text-xs font-medium text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-accent)/10 transition-colors"
>
    {tag}
</a>
    )}
