---
const navLinks = [
    {href: '/', label: 'Blog'},
    {href: '/tags', label: 'Tags'},
    {href: '/about', label: 'Über mich'},
];
---

<header class="sticky top-0 z-50 border-b border-(--color-border) bg-(--color-bg)/80 backdrop-blur-lg">
    <nav class="mx-auto flex max-w-(--content-width-wide) items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight hover:text-(--color-accent) transition-colors">
            <img src="/logo.png" alt="rubeen.dev Logo" class="h-8 w-8 rounded-full object-cover"/>
            rubeen.dev
        </a>

        <div class="flex items-center gap-3 sm:gap-6">
            {navLinks.map((link) => (
                    <a
                            href={link.href}
                            class="text-sm text-(--color-text-secondary) hover:text-(--color-text) transition-colors"
                    >
                        {link.label}
                    </a>
            ))}

            <button
                    id="search-trigger"
                    class="text-(--color-text-muted) hover:text-(--color-text) transition-colors"
                    aria-label="Suche"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
            </button>

            <button
                    id="theme-toggle"
                    class="text-(--color-text-muted) hover:text-(--color-text) transition-colors"
                    aria-label="Theme wechseln"
            >
                <svg class="icon-system" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                    <line x1="8" y1="21" x2="16" y2="21"></line>
                    <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
                <svg class="icon-light" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path d="M12 2v2"></path>
                    <path d="M12 20v2"></path>
                    <path d="m4.93 4.93 1.41 1.41"></path>
                    <path d="m17.66 17.66 1.41 1.41"></path>
                    <path d="M2 12h2"></path>
                    <path d="M20 12h2"></path>
                    <path d="m6.34 17.66-1.41 1.41"></path>
                    <path d="m19.07 4.93-1.41 1.41"></path>
                </svg>
                <svg class="icon-dark" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
                </svg>
            </button>

        </div>
    </nav>
</header>

<script>
const toggle = document.getElementById('theme-toggle');

function getStoredTheme() {
    return localStorage.getItem('theme');
}

function applyTheme() {
    const stored = getStoredTheme();
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const effective = stored || (prefersDark ? 'dark' : 'light');
    document.documentElement.classList.toggle('dark', effective === 'dark');
    document.documentElement.setAttribute('data-theme', stored || 'system');
}

// Toggle: system → light → dark → system
toggle?.addEventListener('click', () => {
    const stored = getStoredTheme();
    if (!stored) {
        localStorage.setItem('theme', 'light');
    } else if (stored === 'light') {
        localStorage.setItem('theme', 'dark');
    } else {
        localStorage.removeItem('theme');
    }
    applyTheme();
});

// React to system preference changes in real-time
window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (!getStoredTheme()) {
        applyTheme();
    }
});

applyTheme();
</script>
