---
import { Image } from 'astro:assets';
import { getInternalLinkCardMetadata, normalizeInternalPath } from '../../lib/link-card-metadata';
import { fetchExternalMetadata } from '../../lib/link-card-cache';
import { SITE_HOSTNAME, SITE_ORIGIN } from '../../lib/site';

interface Props {
    url: string;
    title?: string;
    description?: string;
}

const {url, title, description} = Astro.props;

function getFaviconFallbackLabel(value: string) {
    const hostnameParts = value
        .split('.')
        .map((part) => part.trim())
        .filter(Boolean)
        .filter((part) => !['www', 'com', 'org', 'net', 'dev', 'app', 'io', 'co', 'de'].includes(part.toLowerCase()));
    const source = hostnameParts[0] ?? value;
    const words = source.split(/[^a-z0-9]+/i).filter(Boolean);
    const initials = words.slice(0, 2).map((word) => word[0]?.toUpperCase() ?? '').join('');

    return initials || source.slice(0, 1).toUpperCase() || 'L';
}

let resolvedTitle = title;
let resolvedDescription = description ?? '';
let hostname = '';
let linkLabel = url;
let faviconSrc = '/favicon-32.png';
let faviconFallback = 'L';
let isExternalLink = false;
let heroImage: ImageMetadata | undefined;

try {
    const siteUrl = new URL(Astro.site ?? SITE_ORIGIN);
    const urlObj = new URL(url, siteUrl);
    const isHttpLink = urlObj.protocol === 'http:' || urlObj.protocol === 'https:';
    const isInternalLink = url.startsWith('/') || (isHttpLink && urlObj.origin === siteUrl.origin);
    const normalizedPath = normalizeInternalPath(urlObj.pathname);

    hostname = isInternalLink ? SITE_HOSTNAME : urlObj.hostname.replace('www.', '');
    linkLabel = isInternalLink
        ? normalizedPath === '/'
            ? SITE_HOSTNAME
            : `${SITE_HOSTNAME}${normalizedPath}`
        : hostname;
    isExternalLink = isHttpLink && !isInternalLink;
    faviconFallback = getFaviconFallbackLabel(hostname || linkLabel);

    if (isInternalLink) {
        const metadata = await getInternalLinkCardMetadata(urlObj.pathname);

        resolvedTitle = resolvedTitle ?? metadata?.title ?? linkLabel;
        resolvedDescription = resolvedDescription || metadata?.description || '';
        heroImage = metadata?.image;
    }

    if (isExternalLink) {
        const metadata = await fetchExternalMetadata(urlObj.toString());

        resolvedTitle = resolvedTitle ?? (metadata.title || hostname);
        resolvedDescription = resolvedDescription || metadata.description;
        faviconSrc = metadata.faviconDataUri ?? faviconSrc;
    }
} catch {
    resolvedTitle = resolvedTitle ?? url;
}

resolvedTitle = resolvedTitle ?? linkLabel;
faviconFallback = getFaviconFallbackLabel(hostname || linkLabel);
---

{heroImage ? (
    <a
            href={url}
            class="not-prose group my-4 block overflow-hidden rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) no-underline! hover:no-underline! transition-all hover:border-(--color-accent)/30 hover:shadow-sm"
    >
        <div class="overflow-hidden">
            <Image
                src={heroImage}
                alt=""
                widths={[400, 600]}
                sizes="(max-width: 640px) 100vw, 600px"
                class="block w-full h-40 object-cover !m-0 !rounded-none transition-transform duration-300 group-hover:scale-[1.03]"
            />
        </div>
        <div class="flex items-start gap-4 p-5">
            <div class="min-w-0 flex-1">
                <div class="font-medium text-(--color-text) group-hover:text-(--color-accent) transition-colors">
                    {resolvedTitle}
                </div>
                {resolvedDescription && (
                        <div class="mt-1 text-sm text-(--color-text-secondary) line-clamp-2">
                            {resolvedDescription}
                        </div>
                )}
                <div class="mt-2 text-xs text-(--color-text-muted)">{linkLabel}</div>
            </div>
            <span class="shrink-0 text-(--color-text-muted) group-hover:text-(--color-text-secondary) transition-colors pt-0.5">&rarr;</span>
        </div>
    </a>
) : (
    <a
            href={url}
            target={isExternalLink ? '_blank' : undefined}
            rel={isExternalLink ? 'noopener noreferrer' : undefined}
            class="not-prose group my-4 flex items-center gap-4 rounded-2xl border border-(--color-border) bg-(--color-bg-secondary) p-5 no-underline! hover:no-underline! transition-all hover:border-(--color-accent)/30 hover:shadow-sm"
    >
        <div class="relative flex h-10 w-10 shrink-0 items-center justify-center">
            <span class="absolute text-sm font-medium text-(--color-text-muted)">{faviconFallback}</span>
            <img
                    src={faviconSrc}
                    alt=""
                    width="24"
                    height="24"
                    loading="lazy"
                    class="relative h-6 w-6 object-contain"
                    onerror="this.remove()"
            />
        </div>
        <div class="min-w-0 flex-1">
            <div class="truncate font-medium text-(--color-text) group-hover:text-(--color-text-secondary) transition-colors">
                {resolvedTitle}
            </div>
            {resolvedDescription && (
                    <div class="mt-0.5 truncate text-sm text-(--color-text-secondary)">
                        {resolvedDescription}
                    </div>
            )}
            <div class="mt-1 text-xs text-(--color-text-muted)">{linkLabel}</div>
        </div>
        <span class="shrink-0 text-(--color-text-muted) group-hover:text-(--color-text-secondary) transition-colors">&rarr;</span>
    </a>
)}
