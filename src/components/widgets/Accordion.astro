---
interface Props {
    title: string;
    defaultOpen?: boolean;
}

const {title, defaultOpen = false} = Astro.props;
---

<details
        open={defaultOpen}
        class="not-prose group my-4 rounded-xl border border-(--color-border) bg-(--color-bg-secondary) overflow-hidden"
>
    <summary class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-medium text-(--color-text) hover:bg-(--color-border)/50 transition-colors">
        {title}
        <svg
                class="h-4 w-4 shrink-0 text-(--color-text-muted) transition-transform group-open:rotate-180"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
        >
            <path d="m6 9 6 6 6-6"></path>
        </svg>
    </summary>
    <div class="border-t border-(--color-border) px-5 pt-3 pb-4 text-sm leading-relaxed text-(--color-text-secondary)">
        <slot/>
    </div>
</details>
