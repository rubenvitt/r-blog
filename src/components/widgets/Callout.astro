---
interface Props {
    type?: 'info' | 'warning' | 'tip' | 'danger';
}

const {type = 'info'} = Astro.props;

const config = {
    info: {
        bg: 'bg-blue-500/6 dark:bg-blue-400/8',
        border: 'border-blue-500/10 dark:border-blue-400/15',
        iconBg: 'bg-blue-500/12 dark:bg-blue-400/15',
        iconColor: 'text-blue-600 dark:text-blue-400',
        label: 'Note',
        icon: 'i',
    },
    warning: {
        bg: 'bg-amber-500/6 dark:bg-amber-400/8',
        border: 'border-amber-500/12 dark:border-amber-400/15',
        iconBg: 'bg-amber-500/12 dark:bg-amber-400/15',
        iconColor: 'text-amber-600 dark:text-amber-400',
        label: 'Warning',
        icon: '⚡',
    },
    tip: {
        bg: 'bg-emerald-500/6 dark:bg-emerald-400/8',
        border: 'border-emerald-500/12 dark:border-emerald-400/15',
        iconBg: 'bg-emerald-500/12 dark:bg-emerald-400/15',
        iconColor: 'text-emerald-600 dark:text-emerald-400',
        label: 'Tip',
        icon: '💡',
    },
    danger: {
        bg: 'bg-red-500/6 dark:bg-red-400/8',
        border: 'border-red-500/10 dark:border-red-400/15',
        iconBg: 'bg-red-500/12 dark:bg-red-400/15',
        iconColor: 'text-red-600 dark:text-red-400',
        label: 'Danger',
        icon: '🚨',
    },
};

const c = config[type];
---

<div class={`not-prose my-6 flex gap-3 rounded-xl border ${c.bg} ${c.border} p-4`}>
    <div class={`flex h-5 w-5 shrink-0 items-center justify-center rounded-md text-xs ${c.iconBg}`}>
        <span>{c.icon}</span>
    </div>
    <div>
        <div class={`text-xs font-medium uppercase tracking-wide ${c.iconColor}`}>
            {c.label}
        </div>
        <div class="mt-1 text-sm leading-relaxed text-(--color-text)">
            <slot/>
        </div>
    </div>
</div>
