---
import {Image} from 'astro:assets';

interface Props {
    src: ImageMetadata;
    alt: string;
    caption?: string;
    width?: number;
}

const {src, alt, caption, width} = Astro.props;
---

<figure class="not-prose my-8">
    <Image
            src={src}
            alt={alt}
            width={width}
            class="rounded-xl border border-(--color-border) w-full"
            loading="lazy"
    />
    {caption && (
            <figcaption class="mt-3 text-center text-sm text-(--color-text-muted)">
                {caption}
            </figcaption>
    )}
</figure>
